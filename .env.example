# ─────────────────────────────────────────────────────────────
# NOSTR SHOP — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── NOSTR ────────────────────────────────────────────────────

# Your Nostr public key (hex, not npub).
# The shop will only show products published by this key.
# If left empty, the app auto-generates a key on first run
# and stores it in localStorage.
#
# How to get your hex pubkey:
#   1. Open https://nostrcheck.me/converter/
#   2. Paste your npub → it shows the hex version
#
VITE_OWNER_PUBKEY=

# ── ALBY LIGHTNING API ───────────────────────────────────────
#
# 1. Sign up at https://getalby.com
# 2. Go to: getalby.com/user/settings/developer
# 3. Create a new API token with scope: invoices:create
# 4. Paste the token below
#
VITE_ALBY_API_TOKEN=

# Your Alby Lightning address (yourname@getalby.com)
# Used as fallback LNURL if API is not configured.
VITE_ALBY_LIGHTNING_ADDRESS=yourname@getalby.com

# ─────────────────────────────────────────────────────────────
# PRODUCTION NOTE:
# Do NOT expose VITE_ALBY_API_TOKEN in a public frontend!
# In production, proxy invoice creation through your own
# backend (e.g. a small Express/Cloudflare Worker endpoint).
# See README.md for details.
# ─────────────────────────────────────────────────────────────
